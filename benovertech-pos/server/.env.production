# Production Environment Variables for Vercel
# These are managed in Vercel dashboard under Settings > Environment Variables

# Database URL - Set in Vercel dashboard
# Use PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=${DATABASE_URL}

# Server Port - Vercel assigns this automatically
PORT=3000

# Node Environment
NODE_ENV=production

# Client URL - Set to your Vercel deployment URL
# Format: https://your-project.vercel.app
CLIENT_URL=${CLIENT_URL}
